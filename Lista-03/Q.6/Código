algoritmo "Q.6 Fazer um algoritmo para calcular e imprimir a media aritmética de 10 alunos, tendo como dados de entrada 3 notas semestrais. Depois imprimir situação do aluno que deve obedecer ao seguinte critério: (media maior ou igual a 7, “aprovado”; entre 4 e 6.9, “AF”; menor que 4, “reprovado”), depois imprimir a media geral da turma;"

var
  i: inteiro
  media, media_turma, nota01, nota02, nota03: real
  medias: vetor [1..10] de real
  situacao: vetor [1..10] de caractere
inicio
  para i de 1 ate 10 faca
    escreval("Escreva a 1ª nota do ",i,"ª aluno")
    leia(nota01)
    limpatela

    escreval("Escreva a 2ª nota do ",i,"ª aluno")
    leia(nota02)
    limpatela

    escreval("Escreva a 3ª nota do ",i,"ª aluno")
    leia(nota03)
    limpatela

    media <- (nota01 + nota02 + nota03)/3
    medias[i] <- media

    se media >= 7 entao
      situacao[i] <- "Aprovado"
    fimse

    se 4<=media<=6.9 entao
      situacao[i] <- "AF"
    fimse

    se media<4 entao
      situacao[i] <- "Reprovado"
    fimse

  fimpara

  para i de 1 ate 10 faca
    escreval("A média do 1")
  fimpara

fimalgoritmo
