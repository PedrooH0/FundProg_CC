algoritmo "Q.4 Crie um algoritmo que leia 3 números e imprima o maior valor."

var
  num1, num2, num3, maior: inteiro

inicio

  escreval("Digite 3 números: ")
  leia(num1)
  leia(num2)
  leia(num3)

  maior <- num1

    se (num2 > maior) entao
      maior <- num2
    fimse

    se (num3 > maior) entao
      maior <- num3
    fimse

  escreval("Entre ",num1," ",num2," e ",num3," o maior é: " maior)

fimalgoritmo
