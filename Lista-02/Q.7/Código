algoritmo "Q.7 Escreva um algoritmo para ler um número inteiro e verifique se o número corresponde a um mês válido no calendário (considerando os 12 meses do ano). Depois escrever o nome do mês correspondente; senão escrever uma mensagem “Número corresponde ao um Mês Inválido”."

var
  num: inteiro

inicio

  escreval("Digite um número que corresponta a um mês. Ex: 1 / 2 / ... / 12")
  leia(num)
  
  escolha num
    caso 1
      escreval("O número ",num," corresponde ao mês de Janeiro")
    caso 2
        escreval("O número ",num," corresponde ao mês de Fevereiro")
    caso 3
      escreval("O número ",num," corresponde ao mês de Março")
    caso 4
      escreval("O número ",num," corresponde ao mês de Abril")
    caso 5
      escreval("O número ",num," corresponde ao mês de Maio")
    caso 6
      escreval("O número ",num," corresponde ao mês de Junho")
    caso 7
      escreval("O número ",num," corresponde ao mês de Julho")
    caso 8
      escreval("O número ",num," corresponde ao mês de Agosto")
    caso 9
      escreval("O número ",num," corresponde ao mês de Setembro")
    caso 10
      escreval("O número ",num," corresponde ao mês de Outubro")
    caso 11
      escreval("O número ",num," corresponde ao mês de Novembro")
    caso 12
      escreval("O número ",num," corresponde ao mês de Dezembro")
     
    outrocaso
      escreval("O número corresponde a um Mês Inválido.")

  fimescolha

fimalgoritmo
