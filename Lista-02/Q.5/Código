algoritmo "Q.5 Escrever um algoritmo para ler dois valores numéricos e apresentar a diferença do maior pelo menor."

var
  num1, num2, maior, diferenca: inteiro

inicio

  escreval("Digite dois números: ")
  leia(num1)
  leia(num2)
  maior <- num1

  se (num2 > maior) entao
    maior <- num2
    diferenca <- maior - num1
    escreval("A diferença entre ", maior," e ",num1," é " diferenca)
  senao
    diferenca <- maior - num2
    escreval("A diferença entre ", maior," e ",num2," é " diferenca)
  fimse 

fimalgoritmo
