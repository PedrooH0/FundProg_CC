algoritmo "3) Faça um algoritmo para ler o saldo de 5 clientes. Depois, deverá realizar operações de débito e crédito: lê um crédito aleatório para cada cliente; realizar saque (débito qualquer) da conta de cada cliente; (saldo_atual = crédito - débito). Também testar se saldo atual é suficiente para realizar o saque, confirmando a operação, caso positivo, e negando a operação, caso negativo, mostrando a mensagem 'Saldo insuficiente'. No final, deverá exibir o saldo atualizado de cada cliente."

var
   i: inteiro
   saldo, credito, debito: real
   saldos_list: vetor [1..5] de real


inicio
      para i de 1 ate 5 faca
           escreval("Informe o saldo do cliente ",i,":")
           leia(saldo)
           limpatela
           escreval("Informe o valor de crédito adicionado ao saldo:")
           leia(credito)
           limpatela
           salario_total <- horas_trabalhadas * valor_hora
           
           se (horas_trabalhadas>maior) entao
              maior <- horas_trabalhadas
              funcionario <- i
           fimse
           se (horas_trabalhadas<160) entao
              salarioTotal_list[i] <- 0
           senao
                se (horas_trabalhadas=160) entao
                   salarioTotal_list[i] <- salario_total
                senao
                     salario_extra <- (horas_trabalhadas - 160) * valor_hora * 1.5
                     salarioTotal_list[i] <- salario_total + salario_extra
                fimse
           fimse
      fimpara

      para i de 1 ate 10 faca
           se (salarioTotal_list[i]=0) entao
              escreval("Funcionário ",i)
              escreval("Horas de trabalho abaixo das 160 necessárias")
              escreval("")
           senao
                escreval("Funcionário ",i)
                escreval("Salário total: R$",salarioTotal_list[i])
                escreval("")
           fimse
      fimpara
      
      escreval("Funcionário com mais horas trabalhadas:")
      escreval("Funcionário ",funcionario)
      escreval(maior,"  horas trabalhadas")

fimalgoritmo
