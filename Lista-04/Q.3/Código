algoritmo "3) Faça um algoritmo para ler o saldo de 5 clientes. Depois, deverá realizar operações de débito e crédito: lê um crédito aleatório para cada cliente; realizar saque (débito qualquer) da conta de cada cliente; (saldo_atual = crédito - débito). Também testar se saldo atual é suficiente para realizar o saque, confirmando a operação, caso positivo, e negando a operação, caso negativo, mostrando a mensagem 'Saldo insuficiente'. No final, deverá exibir o saldo atualizado de cada cliente."

var
   i: inteiro
   saldoInicial_list: vetor [1..5] de real
   credito_list: vetor [1..5] de real
   debito_list: vetor [1..5] de  real
   saldoFinal_list: vetor [1..5] de real

inicio
      para i de 1 ate 5 faca
           escreval("Informe o saldo do cliente ",i,":")
           leia(saldoInicial_list[i])
           limpatela
           escreval("Informe o valor de crédito adicionado ao saldo:")
           leia(credito_list[i])
           limpatela
           escreval("Informe o valor de débito que deseja retirar do saldo:")
           leia(debito_list[i])
           limpatela
           saldoFinal_list[i] <- (saldoInicial_list[i] + credito_list[i]) - debito_list[i]
      fimpara

      para i de 1 ate 5 faca
           se (saldoFinal_list[i]<0) entao
              saldoFinal_list[i] <- saldoInicial_list[i] + credito_list[i]
              escreval("Cliente ",i)
              escreval("Saldo inicial: R$",saldoInicial_list[i])
              escreval("Valor de crédito acrescentado: R$",credito_list[i])
              escreval("Valor de débito para retirar do saldo: R$",debito_list[i])
              escreval("Saldo insuficiente")
              escreval("Saldo final: R$",saldoFinal_list[i])
              escreval("")
           senao
              escreval("Cliente ",i)
              escreval("Saldo inicial: R$",saldoInicial_list[i])
              escreval("Valor de crédito acrescentado: R$",credito_list[i])
              escreval("Valor de débito para retirar do saldo: R$",debito_list[i])
              escreval("Saldo final: R$",saldoFinal_list[i])
              escreval("")
           fimse
      fimpara

fimalgoritmo
